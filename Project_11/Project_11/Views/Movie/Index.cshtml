@model List<Movie>

@{
    ViewData["Title"] = "Фільми";
}

<h2>🎬 Менеджер фільмів</h2>

<form method="get" asp-action="Index" class="row g-3 mb-4 mt-2">
    <div class="col-auto">
        <select name="genre" class="form-select">
            <option value="">-- Усі жанри --</option>
            @foreach (var g in (List<string?>)ViewBag.Genre)
            {
                <option value="@g" selected="@(ViewBag.SelectedGenre == g)">@g</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <select name="year" class="form-select">
            <option value="">-- Усі роки --</option>
            @foreach (var y in (List<int>)ViewBag.Years)
            {
                <option value="@y" selected="@(ViewBag.SelectedYear != null && (int)ViewBag.SelectedYear == y)">@y</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Фільтрувати</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Скинути</a>
    </div>
</form>

<a asp-action="Create" class="btn btn-success mb-3">+ Додати фільм</a>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Фільмів не знайдено.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Назва</th>
                <th>Жанр</th>
                <th>Рік</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var movie in Model)
            {
                <tr>
                    <td>@movie.Title</td>
                    <td>@movie.Genre</td>
                    <td>@movie.Year</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@movie.Id" class="btn btn-sm btn-warning">Редагувати</a>
                        <a asp-action="Delete" asp-route-id="@movie.Id" class="btn btn-sm btn-danger">Видалити</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
